{
    "version": 2,
    "buildCommand": "npm run build 2>&1 || true",
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.8.0",
            "maxDuration": 30
        }
    },
    "routes": [
        {
            "src": "/build/(.*)",
            "dest": "/public/build/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "outputDirectory": "public"
}