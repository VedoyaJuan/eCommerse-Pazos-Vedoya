{
    "version": 2,
    "buildCommand": "composer install --no-interaction --prefer-dist --optimize-autoloader && npm install && npm run build && php artisan config:clear 2>/dev/null; php artisan config:cache && php artisan clear-compiled && php artisan package:discover --ansi",
    "env": {
        "APP_CONFIG_CACHE": "/tmp/laravel-config.php",
        "APP_ENV": "production",
        "LOG_STACK": "stderr",
        "CACHE_STORE": "file",
        "SESSION_DRIVER": "file",
        "QUEUE_CONNECTION": "sync"
    },
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.8.0",
            "maxDuration": 30,
            "memory": 3008
        }
    },
    "routes": [
        {
            "src": "/build/(.*)",
            "dest": "/public/build/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "outputDirectory": "public"
}