{
    "version": 2,
    "buildCommand": "composer install --optimize-autoloader && npm install && npm run build && php artisan config:cache && php artisan clear-compiled",
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "false",
        "LOG_STACK": "stderr",
        "CACHE_STORE": "file",
        "SESSION_DRIVER": "file",
        "QUEUE_CONNECTION": "sync",
        "FILESYSTEM_DISK": "local"
    },
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.8.0",
            "maxDuration": 30,
            "memory": 2048
        }
    },
    "routes": [
        {
            "src": "/build/(.*)",
            "dest": "/public/build/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "outputDirectory": "public"
}